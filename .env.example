# ============================================================
#  DataCycleProject – Environment Configuration Template
#  Copy this file to .env and fill in the real values.
#  NEVER commit .env to source control.
# ============================================================

# --- Google Cloud Platform ---
GCP_PROJECT=your-gcp-project-id
GCS_BUCKET=your-gcs-bucket-name
BQ_DATASET=DataCycle_Warehouse
BQ_LOCATION=EU

# --- Google Service Account ---
# Full Windows path to the service account JSON key file
GOOGLE_APPLICATION_CREDENTIALS=C:\Users\Administrator\Desktop\Auth\your-service-account.json

# --- Windows VM ---
# Absolute path to the root of this repository on the VM
ROOT_DIR=C:\Users\Administrator\Desktop\DataCycleProject

# --- SFTP – Weather Forecast Data Source ---
SFTP_HOST=10.130.25.152
SFTP_USER=Student
SFTP_PASS=your-sftp-password

# --- KNIME Predictions ---
KNIME_ID=your-knime-app-id
KNIME_PASSWORD=your-knime-password
KNIME_DEPLOYMENT_URL=https://api.edu-hub.knime.com/deployments/rest:your-deployment-id/execution?reset=true&timeout=-1

# --- SMB Network Drives (Windows mapped drive letters, without colon) ---
SMB_CONSO_DRIVE=Y
SMB_BOOKING_DRIVE=X
SMB_SOLAR_DRIVE=Z
